# Copy to .env.local and fill in. All VITE_* vars are embedded in the client
# bundle at build time. The ANON key is public-safe (RLS protects data); the
# SERVICE-ROLE key must NEVER be placed here or anywhere in the repo.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# The single admin account. This only toggles admin UI on the client; the
# database independently enforces admin writes via the is_admin() function
# (see schema.sql / app_config). Keep this email in sync with app_config.
VITE_ADMIN_EMAIL=admin@worldcup.com

# Optional: where the "Refresh results" button fetches the official results
# JSON. Defaults to the bundled ./wc2026_matches.json. Point it at a hosted/
# updated copy to refresh results without redeploying.
# VITE_RESULTS_URL=./wc2026_matches.json
